{
  "name": "desk-app",
  "version": "0.0.8",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "Jiří Žák <jiri.zak89@seznam.cz>",
  "type": "module",
  "private": true,
  "imports": {
    "#root/*": "./*",
    "#src/*": "./src/*",
    "#electron/*": "./src-electron/*",
    "#db/*": "./db/*",
    "#tools/*": "./tools/*"
  },
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron",
    "electron:rebuild-native": "electron-rebuild -w better-sqlite3",
    "build:electron": "quasar build -m electron",
    "db:generate": "node ./db/scripts/run-drizzle-runtime.mjs generate",
    "db:check": "node ./db/scripts/run-drizzle-runtime.mjs check",
    "db:migrate": "node ./db/scripts/run-drizzle-runtime.mjs migrate",
    "db:push": "node ./db/scripts/run-drizzle-runtime.mjs push",
    "db:pull": "node ./db/scripts/run-drizzle-runtime.mjs pull",
    "db:studio": "node ./db/scripts/run-drizzle-runtime.mjs studio",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "axios": "^1.2.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.0.12"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.14.0",
    "@intlify/unplugin-vue-i18n": "^4.0.0",
    "@quasar/app-vite": "^2.1.0",
    "@types/node": "^20.5.9",
    "@types/better-sqlite3": "^7.6.12",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "autoprefixer": "^10.4.2",
    "drizzle-kit": "^0.31.7",
    "electron": "^40.0.0",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.9.2",
    "vite-plugin-checker": "^0.11.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
